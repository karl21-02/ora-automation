# ── Database ──────────────────────────────────────
POSTGRES_DB=ora_automation
POSTGRES_USER=ora
POSTGRES_PASSWORD=your-secure-password
DATABASE_URL=postgresql+psycopg://ora:your-secure-password@db:5432/ora_automation

# ── RabbitMQ ──────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F

# ── GCP / Gemini (required for LLM features) ──────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_FALLBACK_LOCATIONS=us-central1,us-east1,europe-west1

# ── GitHub App (optional) ─────────────────────────
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_WEBHOOK_SECRET=
# ORA_CLONE_BASE_DIR=/tmp/ora-clones

# ── Notion (optional) ────────────────────────────
# NOTION_API_TOKEN=
# NOTION_AUTO_PUBLISH=0

# ── Scheduler (optional) ─────────────────────────
# ORA_SCHEDULER_ENABLED=0
# ORA_SCHEDULER_POLL_SECONDS=60

# ── Orchestration ────────────────────────────────
# ORA_AUTOMATION_ROOT=/path/to/ora-automation
# ORA_PROJECTS_ROOT=/path/to/your/projects
# ORCHESTRATION_PROFILE=standard
# DEBATE_ROUNDS=2
# TOP=6
