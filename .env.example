# ── Database ──────────────────────────────────────
POSTGRES_DB=ora_automation
POSTGRES_USER=ora
POSTGRES_PASSWORD=ora
DATABASE_URL=postgresql+psycopg://ora:ora@db:5432/ora_automation

# ── RabbitMQ ──────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/%2F

# ── GCP / Gemini ──────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=ora-project-474413
GOOGLE_CLOUD_LOCATION=asia-northeast3
GOOGLE_APPLICATION_CREDENTIALS=/workspace/Ora/ora-automation/google-service-account.json
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_CLOUD_FALLBACK_LOCATIONS=us-central1,us-east1,europe-west1

# ── Notion (optional) ────────────────────────────
# NOTION_API_TOKEN=
# NOTION_AUTO_PUBLISH=0

# ── Scheduler (optional) ─────────────────────────
# ORA_SCHEDULER_ENABLED=0
# ORA_SCHEDULER_POLL_SECONDS=60
