# Copy this file to terraform.tfvars and fill in your values

project_id              = "your-gcp-project-id"
region                  = "asia-northeast3"
zone                    = "asia-northeast3-a"
machine_type            = "e2-medium"  # 2 vCPU, 4GB RAM - Docker needs memory

# Gemini API (optional - can be added later via SSH)
google_cloud_project_id = "your-gcp-project-id"

# GitHub repo (must be public, or use deploy key)
github_repo             = "https://github.com/karl21-02/ora-automation.git"
